[MeterSectionAccent]
Meter=Shape
X=#SectionAccentX#
Y=#SectionAccentY#
Shape=#SectionAccentShape# | Fill Color #ColorBrandForeground# | StrokeWidth 0

[MeterSectionTitle]
Meter=String
X=#SectionTitleX#
Y=#SectionTitleY#
Text=#SectionTitle#
MeterStyle=MeterStylePrimary
FontColor=#ColorNeutralForegroundSecondary#
FontSize=#SectionTitleSize#
