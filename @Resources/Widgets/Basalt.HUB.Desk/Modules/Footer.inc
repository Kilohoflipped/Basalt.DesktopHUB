[MeterDividerFooter]
Meter=Shape
X=#PanelPaddingX#
Y=#FooterDividerY#
Shape=Rectangle 0,0,#PanelInnerW#,1 | Fill Color #Line# | StrokeWidth 0

[MeterFooterMark]
Meter=String
MeterStyle=MeterStyleSymbol
Text=#FooterMark#
X=#FooterMarkX#
Y=#FooterMarkY#
FontSize=28
FontColor=#TextPrimary#

[MeterFooterName]
Meter=String
MeterStyle=MeterStylePrimary
Text=#FooterName#
X=#FooterNameX#
Y=#FooterNameY#
FontSize=10
FontColor=#TextPrimary#
StringStyle=Bold

[MeterFooterChinese]
Meter=String
MeterStyle=MeterStylePrimary
Text=#FooterChinese#
X=#FooterChineseX#
Y=#FooterChineseY#
FontSize=9
FontColor=#TextSecondary#

[MeterFooterTagline]
Meter=String
MeterStyle=MeterStyleMono
Text=#FooterTagline#
X=#FooterTaglineX#
Y=#FooterTaglineY#
FontSize=8
FontColor=#TextMuted#
StringAlign=Right

[MeterFooterCode]
Meter=String
MeterStyle=MeterStyleMono
Text=#FooterCode#
X=#PanelPaddingX#
Y=#FooterCodeY#
FontSize=8
FontColor=#TextMuted#

[MeterFooterBars]
Meter=String
MeterStyle=MeterStyleMono
Text=#FooterBars#
X=#FooterBarsX#
Y=#FooterBarsY#
FontSize=9
FontColor=#Accent#
StringAlign=Right
