[Variables]
; ==================================
; Shadow：阴影颜色。
; Ambient 与 Key 应作为一组共同组成一层阴影。
; ==================================

; 中性表面的默认阴影。
ColorNeutralShadowAmbient=#Neutral000#1F
ColorNeutralShadowKey=#Neutral000#24

; 轻层级阴影。
; 用于轻浮起的卡片、Hover Tile、轻量 Popover 等。
ColorNeutralShadowAmbientLighter=#Neutral000#0F
ColorNeutralShadowKeyLighter=#Neutral000#12

; 强层级阴影。
; 用于浮层、Dialog、悬浮重点容器等。
ColorNeutralShadowAmbientDarker=#Neutral000#33#
ColorNeutralShadowKeyDarker=#Neutral000#3D#

; 品牌表面的阴影。
; 用于品牌色按钮、品牌卡片或品牌强调容器。
ColorBrandShadowAmbient=#Neutral000#4D
ColorBrandShadowKey=#Neutral000#40