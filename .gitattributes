# -----------------------------------------------------------------------------
# Basalt.DesktopHUB - Git 属性与 Git LFS 规则
#
# 目标：
#   1. 让 Rainmeter 配置文件产生可读的文本差异。
#   2. 在 Windows 工作区中统一使用 CRLF 换行。
#   3. 保持本地化 Strings.inc 为带 BOM 的 UTF-16 LE。
#   4. 使用 Git LFS 管理图片、字体、压缩包和 Rainmeter 安装包。
# -----------------------------------------------------------------------------

# 默认自动识别文本文件，并规范化仓库内部的文本表示。
* text=auto

# Rainmeter 配置文件和 Include 文件在工作区中使用 CRLF。
*.ini text eol=crlf
*.inc text eol=crlf

# 所有本地化字符串表包含中文，工作区必须保持 UTF-16 LE BOM。
# Git 内部会保存规范化后的 UTF-8 内容，使历史记录与差异仍然可读。
**/Strings.inc text eol=crlf working-tree-encoding=UTF-16LE-BOM

# 仓库控制文件与常见文档使用 LF，方便跨平台查看和审阅。
.gitignore     text eol=lf
.gitattributes text eol=lf
*.md           text eol=lf
*.txt          text eol=lf
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.xml          text eol=lf
*.svg          text eol=lf

# 如果以后加入辅助脚本，按其目标平台指定换行方式。
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh  text eol=lf
*.py  text eol=lf

# Git LFS：位图与图标资源
*.png  filter=lfs diff=lfs merge=lfs -text
*.jpg  filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif  filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.ico  filter=lfs diff=lfs merge=lfs -text
*.bmp  filter=lfs diff=lfs merge=lfs -text
*.svgz filter=lfs diff=lfs merge=lfs -text

# Git LFS：字体资源
*.ttf   filter=lfs diff=lfs merge=lfs -text
*.otf   filter=lfs diff=lfs merge=lfs -text
*.woff  filter=lfs diff=lfs merge=lfs -text
*.woff2 filter=lfs diff=lfs merge=lfs -text

# Git LFS：归档文件、文档成品与 Rainmeter 安装包
*.zip    filter=lfs diff=lfs merge=lfs -text
*.7z     filter=lfs diff=lfs merge=lfs -text
*.rar    filter=lfs diff=lfs merge=lfs -text
*.pdf    filter=lfs diff=lfs merge=lfs -text
*.rmskin filter=lfs diff=lfs merge=lfs -text
